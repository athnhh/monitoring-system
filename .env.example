# ═══════════════════════════════════════════════
# Quemahtech Employee Management System — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
# ═══════════════════════════════════════════════

PORT=3000

# ── Application ──
APP_NAME=Quemahtech EMS

# ── Admin Account (configured on first startup) ──
ADMIN_USERNAME=quemahtech
ADMIN_EMAIL=atharvashishn@gmail.com

# ── MongoDB (REQUIRED for data persistence) ──
# Get a free cluster at https://www.mongodb.com/atlas
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/quemahtech
# For local development: mongodb://localhost:27017/quemahtech
DATABASE_URL=
