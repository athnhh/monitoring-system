# ═══════════════════════════════════════════════
# Quemahtech Employee Management System — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
#
# FIREBASE: Get your service account JSON at:
#   https://console.firebase.google.com → Project Settings → Service Accounts → Generate New Private Key
# SMTP: Create a Gmail App Password at https://myaccount.google.com/apppasswords
# ═══════════════════════════════════════════════

PORT=3000

# ── Application ──
APP_NAME=Quemahtech EMS

# ── Admin Account (configured on first startup) ──
ADMIN_USERNAME=quemahtech
ADMIN_EMAIL=atharvashishn@gmail.com

# ── Firebase Admin SDK (Firestore Database) ──
# Path to your Firebase Admin SDK service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=quemahtech-e9148-firebase-adminsdk-fbsvc-72d38afb10.json

# ── SMTP (Gmail App Password recommended) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=atharvashishn@gmail.com
SMTP_PASS=your-gmail-app-password
