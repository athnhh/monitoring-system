# ═══════════════════════════════════════════════
# Quemahtech Employee Management System - Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
#
# MONGODB: Get a free cluster at https://mongodb.com/cloud/atlas
# SMTP: Create a Gmail App Password at https://myaccount.google.com/apppasswords
# ═══════════════════════════════════════════════

PORT=3000

# MongoDB Connection String
# Get this from MongoDB Atlas: Database > Connect > Drivers > Connection string
DATABASE_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/quemahtech?retryWrites=true&w=majority

# SMTP Configuration (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
