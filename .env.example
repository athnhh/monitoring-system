# ═══════════════════════════════════════════════
# Quemahtech Employee Management System — Firebase Config
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your Firebase credentials.
# The app will fall back to local file storage (data.json) if Firebase
# is not configured.
#
# HOW TO GET THESE CREDENTIALS:
# 1. Go to https://console.firebase.google.com/
# 2. Create or select your project
# 3. Go to Project Settings → Service Accounts → "Generate New Private Key"
# 4. This downloads a JSON file. The values in that file map to these env vars.
# ═══════════════════════════════════════════════

# Your Firebase project ID (from Project Settings)
FIREBASE_PROJECT_ID=your-project-id

# Service account client email (from the downloaded JSON key file)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Service account private key (from the downloaded JSON key file)
# IMPORTANT: Wrap in quotes and keep the \n characters intact
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Realtime Database URL (from Realtime Database section)
# Format: https://your-project-id-default-rtdb.region.firebasedatabase.app
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
