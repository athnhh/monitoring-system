{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "dist/**", "use": "@vercel/static" },
    { "src": "firebase-config.js", "use": "@vercel/static" },
    { "src": "firebase.js", "use": "@vercel/static" },
    { "src": "logo.webp", "use": "@vercel/static" },
    { "src": "photo.jpeg", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth/login", "dest": "server.js", "methods": ["POST", "OPTIONS"] },
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/", "dest": "/dist/index.html" },
    { "src": "/(.*)", "dest": "/dist/$1", "check": true },
    { "src": "/(.*)", "dest": "/dist/index.html" }
  ]
}
